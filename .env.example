# ============================================
# API Keys Configuration
# ============================================

# Groq Cloud API Key (Get from: https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Tavily Search API Key (Get from: https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# Model Configuration
# ============================================

# Groq Model Options:
# - llama-3.3-70b-versatile (Recommended - Best balance)
# - llama-3.1-70b-versatile
# - llama-3.1-8b-instant (Fastest)
# - mixtral-8x7b-32768
# - gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# Model Temperature (0.0 = deterministic, 1.0 = creative)
MODEL_TEMPERATURE=0.0

# ============================================
# Application Settings
# ============================================

# Maximum search results to fetch
MAX_SEARCH_RESULTS=5

# Maximum characters to scrape from URL
MAX_SCRAPE_LENGTH=3000

# Request timeout in seconds
REQUEST_TIMEOUT=8

# ============================================
# Cache Settings
# ============================================

# Enable/disable caching (true/false)
ENABLE_CACHE=true

# Cache expiry time in hours
CACHE_EXPIRY_HOURS=24

# ============================================
# Retry Settings
# ============================================

# Maximum number of retries for failed requests
MAX_RETRIES=3

# Minimum wait time between retries (seconds)
RETRY_MIN_WAIT=1

# Maximum wait time between retries (seconds)
RETRY_MAX_WAIT=10

# ============================================
# Validation Settings
# ============================================

# Minimum topic length
MIN_TOPIC_LENGTH=3

# Maximum topic length
MAX_TOPIC_LENGTH=200

# ============================================
# Logging Settings
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
